# Copy this file to .env and fill in your values
# Never commit .env to git — it is already in .gitignore

# ─── Required ────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Optional ────────────────────────────────────────────
# Enables Cohere rerank-english-v3.0 reranking
# Without this, top-5 RRF results are used directly
# Get a free key at https://dashboard.cohere.com
#COHERE_API_KEY=your_cohere_api_key_here

# Only needed to run RAGAS evaluation (evaluation/evaluate.py)
# Uses GPT-4o as judge — costs ~$0.05–0.20 per run
#OPENAI_API_KEY=your_openai_api_key_here 
